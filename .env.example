REACTOR_API_KEY=rk_your_api_key
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Optional defaults
# LIVEKIT_ROOM_NAME=reactor-youtube
# LIVEKIT_PARTICIPANT_IDENTITY=reactor-bridge
# LIVEKIT_API_URL=https://your-project.livekit.cloud

# Optional: prompt scheduled at frame 0 before sending start
# REACTOR_START_PROMPT=A cinematic ocean with golden light

# Preferred: full YouTube ingest URL
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2/xxxx-xxxx-xxxx-xxxx-xxxx

# Optional fallback if YOUTUBE_RTMP_URL is not set
# YT_STREAM_KEY=xxxx-xxxx-xxxx-xxxx-xxxx
# YT_RTMP_BASE=rtmp://a.rtmp.youtube.com/live2

# Optional: enable YouTube chat -> Reactor prompt relay.
# Any chat message matching "/prompt <content>" is submitted to LiveCore.
# YOUTUBE_API_KEY=AIza...
# YOUTUBE_VIDEO_ID=abc123xyz00
